{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm -rf /*)",
      "Bash(sudo *)"
    ]
  }
}
